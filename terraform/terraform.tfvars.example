# AWS deployment configuration overrides
# Rename this file to terraform.tfvars to supply custom settings

# The target AWS Region (defaults to us-east-1)
# aws_region = "us-east-1"

# VPC network CIDR blocks (defaults shown below)
# vpc_cidr            = "10.0.0.0/16"
# public_subnet_cidr  = "10.0.1.0/24"
# private_subnet_cidr = "10.0.2.0/24"

# Compute instance sizing
# Note: inference_instance_type is recommended as c7i-flex.large (utilizing 8GB swap memory for the Gemma model)
# engine_instance_type    = "t3.micro"
# inference_instance_type = "c7i-flex.large"
# caller_instance_type    = "t3.micro"
# nat_instance_type       = "t3.nano"

# Restrict SSH access to your public IP for enhanced security (strongly recommended).
# Find your IP via https://ipv4.icanhazip.com or curl https://ifconfig.me
# Example: my_ip = "203.0.113.50/32"
my_ip = "0.0.0.0/0"
